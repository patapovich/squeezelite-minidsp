#!/bin/bash
# Maps squeezelite volume (0-100) to minidsp master gain via a tunable curve.
#
#   gain = FLOOR_DB * (1 - (vol/100)^CURVE_K)
#
# Slider 100 is always 0 dB. Slider 0 is a no-op (see below).
#
# Tunables (override via env or systemd EnvironmentFile):
#   FLOOR_DB  Maximum attenuation when vol approaches 1 (default -50).
#             Lower magnitude = less dynamic range, higher minimum loudness.
#   CURVE_K   Curve exponent (default 1.0 = linear). >1 = bottom-heavy
#             attenuation (slider 1-30 stays near floor, top of slider gets
#             steeper). Try 1.5, 2, 2.5, 3. <1 = top-heavy (audio-taper feel).
VOL=${1:-0}
FLOOR_DB=${FLOOR_DB:--50}
CURVE_K=${CURVE_K:-1}

# Debounce: squeezelite launches each volume call asynchronously, so multiple
# instances run simultaneously during LMS fade ramps (pause-fade-out,
# unpause-fade-in, power-on). Every call writes its value to REQFILE
# FIRST — including VOL=0 — so that pending earlier sleeping calls see a
# newer value and exit. If we early-exited on VOL=0 before writing, the
# penultimate ramp step (e.g. VOL=9) would not be overwritten and would
# wake, find its own value still in the file, and apply itself — leaving
# the device near the floor every pause.
REQFILE=/tmp/sq-volume-req
echo "$VOL" > "$REQFILE"

# Slider 0: don't touch the device. LMS sends vol=0 on pause/stop, and on
# a multi-input MiniDSP (USB + Toslink etc.) hard-muting the master also
# silences whatever external source is currently playing. Squeezelite is
# paused so no audio from it is flowing anyway; leaving the master gain
# alone keeps Toslink (or whatever input is selected) playing at the
# previous level, and HA's volume slider doesn't snap to 0 on every pause.
if [ "$VOL" -eq 0 ]; then
    exit 0
fi

sleep 0.3
[ "$(cat "$REQFILE" 2>/dev/null)" = "$VOL" ] || exit 0

GAIN=$(LC_NUMERIC=C awk -v v="$VOL" -v f="$FLOOR_DB" -v k="$CURVE_K" \
    'BEGIN { printf "%.1f", f * (1 - (v/100.0)^k) }')

for i in 1 2 3; do
    minidsp gain -- "$GAIN" 2>/dev/null && exit 0
    sleep 0.5
done
