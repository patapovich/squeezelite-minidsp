#!/bin/bash
# Maps squeezelite volume (0-100) to minidsp master gain via a tunable curve.
#
#   gain = FLOOR_DB * (1 - (vol/100)^CURVE_K)
#
# Slider 100 is always 0 dB. Slider 0 is a no-op (see below).
#
# Tunables (override via env or systemd EnvironmentFile):
#   FLOOR_DB  Maximum attenuation when vol approaches 1 (default -50).
#             Lower magnitude = less dynamic range, higher minimum loudness.
#   CURVE_K   Curve exponent (default 1.0 = linear). >1 = bottom-heavy
#             attenuation (slider 1-30 stays near floor, top of slider gets
#             steeper). Try 1.5, 2, 2.5, 3. <1 = top-heavy (audio-taper feel).
VOL=${1:-0}
FLOOR_DB=${FLOOR_DB:--50}
CURVE_K=${CURVE_K:-1}

# Slider 0: do nothing. LMS sends vol=0 on pause/stop, and on a multi-input
# MiniDSP (USB + Toslink etc.) hard-muting the master also silences whatever
# external source is currently playing. Squeezelite is paused so no audio
# from it is reaching the device anyway; leaving the master gain alone means
# Toslink (or any other selected input) keeps playing at the previous level,
# and HA's volume slider doesn't snap to 0 on every pause.
if [ "$VOL" -eq 0 ]; then
    exit 0
fi

# Debounce: squeezelite launches each volume call asynchronously, so multiple
# instances run simultaneously during LMS fade-in on power-on. Write our
# requested value, wait briefly, then skip if a later call overwrote it.
REQFILE=/tmp/sq-volume-req
echo "$VOL" > "$REQFILE"
sleep 0.3
[ "$(cat "$REQFILE" 2>/dev/null)" = "$VOL" ] || exit 0

GAIN=$(LC_NUMERIC=C awk -v v="$VOL" -v f="$FLOOR_DB" -v k="$CURVE_K" \
    'BEGIN { printf "%.1f", f * (1 - (v/100.0)^k) }')

for i in 1 2 3; do
    minidsp gain -- "$GAIN" 2>/dev/null && exit 0
    sleep 0.5
done
